# CloudPSS Skills 环境配置示例
# 复制此文件为 .env 并填入实际值

# =====================================================
# CloudPSS API 配置
# =====================================================
# 在 www.cloudpss.net 获取 API Key
CLOUDPSS_API_KEY=your-cloudpss-api-key-here

# API 基础 URL (通常不需要修改)
CLOUDPSS_API_BASE_URL=https://www.cloudpss.net/api

# 默认项目 ID (可选)
CLOUDPSS_PROJECT_ID=

# =====================================================
# Symphony Framework 配置
# =====================================================
SYMPHONY_API_KEY=symphony-local-key-2026
SYMPHONY_LOG_LEVEL=info
SYMPHONY_WORKSPACE_ROOT=./workspace
SYMPHONY_MAX_CONCURRENT=3

# =====================================================
# 开发配置
# =====================================================
NODE_ENV=development
DEBUG=cloudpss:*

# CloudPSS Skills 环境配置示例
# 复制此文件为 .env 并填入实际值

# =====================================================
# CloudPSS API 配置
# =====================================================
# 在 www.cloudpss.net 获取 API Token
# 注意：统一使用 CLOUDPSS_TOKEN，CLOUDPSS_API_KEY 已废弃（仅向后兼容）
CLOUDPSS_TOKEN=your-cloudpss-token-here

# API 基础 URL (通常不需要修改)
CLOUDPSS_API_URL=https://cloudpss.net/

# =====================================================
# Symphony Framework 配置
# =====================================================
SYMPHONY_API_KEY=symphony-local-key-2026
SYMPHONY_LOG_LEVEL=info
SYMPHONY_WORKSPACE_ROOT=./workspace
SYMPHONY_MAX_CONCURRENT=3

# =====================================================
# 开发配置
# =====================================================
NODE_ENV=development
DEBUG=cloudpss:*
